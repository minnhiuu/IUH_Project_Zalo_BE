pipeline {
    agent any
    tools { maven 'maven-3.9' }

    environment {
        AWS_ACCOUNT_ID = "952647925716"
        AWS_REGION     = "ap-southeast-2"
        IMAGE_REPO     = "bondhub/config-server"
        IMAGE_TAG      = "${env.BUILD_NUMBER}"
        ECR_URL        = "${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com"
        TOOLS_DIR      = "/var/jenkins_home/tools"
    }

    stages {
        stage('Setup Tools') {
            steps {
                script {
                    sh '''
                        mkdir -p ${TOOLS_DIR}

                        echo "=== Installing Docker CLI ==="
                        if [ ! -x ${TOOLS_DIR}/docker ]; then
                            curl -sL https://download.docker.com/linux/static/stable/x86_64/docker-27.3.1.tgz | tar -xz -C /tmp
                            mv /tmp/docker/docker ${TOOLS_DIR}/docker
                            rm -rf /tmp/docker
                        fi

                        echo "=== Installing kubectl ==="
                        if [ ! -x ${TOOLS_DIR}/kubectl ]; then
                            curl -sLO "https://dl.k8s.io/release/$(curl -sL https://dl.k8s.io/release/stable.txt)/bin/linux/amd64/kubectl"
                            chmod +x kubectl
                            mv kubectl ${TOOLS_DIR}/kubectl
                        fi

                        echo "=== Verification ==="
                        ${TOOLS_DIR}/docker --version
                        ${TOOLS_DIR}/kubectl version --client
                    '''
                }
            }
        }

        stage('Maven Build') {
            steps {
                dir('config-server') {
                    script {
                        sh 'mvn -f ../pom.xml install -N' 
                        sh 'mvn -f ../common/pom.xml clean install -DskipTests'
                        sh 'mvn clean package -DskipTests'
                    }
                }
            }
        }

        stage('Docker Build & Push') {
            steps {
                script {
                    // Thêm tools vào PATH để plugin Docker nhận diện được
                    withEnv(["PATH+TOOLS=${TOOLS_DIR}"]) {
                        docker.withRegistry("https://${ECR_URL}", "ecr:${AWS_REGION}:aws-credentials-id") {
                            dir('config-server') {
                                def customImage = docker.build("${IMAGE_REPO}:${IMAGE_TAG}")
                                customImage.push()
                                customImage.push("latest")
                            }
                        }
                    }
                }
            }
        }

        stage('Deploy to EKS') {
            steps {
                withKubeConfig([credentialsId: 'eks-creds-id', clusterName: 'bondhub-cluster-final']) {
                    sh "${TOOLS_DIR}/kubectl set image deployment/config-server-deploy config-server=${ECR_URL}/${IMAGE_REPO}:${IMAGE_TAG} -n bondhub"
                }
            }
        }
    }
}
