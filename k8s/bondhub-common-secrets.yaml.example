apiVersion: v1
kind: Secret
metadata:
  name: bondhub-common-secrets
  namespace: bondhub
type: Opaque
stringData:
  # Database Passwords
  MONGO_INITDB_ROOT_PASSWORD: "your-mongo-root-password"
  REDIS_PASSWORD: "your-redis-password"
  NEO4J_PASSWORD: "your-neo4j-password"
  
  # Auth
  JWT_SECRET: "your-jwt-secret-base64"
  ADMIN_PASSWORD: "your-admin-password"

  # Third Party APIs
  BREVO_API_KEY: "your-brevo-api-key"
  AWS_ACCESS_KEY: "your-aws-access-key"
  AWS_SECRET_KEY: "your-aws-secret-key"
  OPENAI_API_KEY: "your-openai-api-key"
  TAVILY_API_KEY: "your-tavily-api-key"
  LANGCHAIN_API_KEY: "your-langchain-api-key"
  ZEGO_SERVER_SECRET: "your-zego-server-secret"

  # MongoDB URIs (Use service names for internal cluster access)
  MONGODB_URI_AUTH: "mongodb://root:password@bh-mongodb:27017/bondhub_auth?authSource=admin"
  MONGODB_URI_USERS: "mongodb://root:password@bh-mongodb:27017/bondhub_user?authSource=admin"
  MONGODB_URI_SEARCH: "mongodb://root:password@bh-mongodb:27017/bondhub_search?authSource=admin"
  MONGODB_URI_FILES: "mongodb://root:password@bh-mongodb:27017/bondhub_files?authSource=admin"
  MONGODB_URI_MESSAGES: "mongodb://root:password@bh-mongodb:27017/bondhub_messages?authSource=admin"
  MONGODB_URI_NOTIFICATIONS: "mongodb://root:password@bh-mongodb:27017/bondhub_notifications?authSource=admin"
  MONGODB_URI_FRIENDSHIPS: "mongodb://root:password@bh-mongodb:27017/bondhub_friendships?authSource=admin"
  MONGODB_URI_AI_SERVICE: "mongodb://root:password@bh-mongodb:27017/bondhub_ai_service?authSource=admin"
  MONGODB_URI_SOCIAL_FEED: "mongodb://root:password@bh-mongodb:27017/bondhub_social?authSource=admin"
