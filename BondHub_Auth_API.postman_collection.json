{
  "info": {
    "name": "BondHub Auth Service API",
    "description": "Authentication endpoints via API Gateway - All routes use /api/* prefix and JWT authentication is handled at the gateway level. Config managed in config-server.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_postman_id": "bondhub-auth-collection",
    "version": "1.0.0"
  },
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Register Step 1: Initiate",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var jsonData = pm.response.json();",
                  "    console.log(\"OTP sent to: \" + jsonData.data.email);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "raw": "{\n  \"email\": \"testuser@example.com\",\n  \"password\": \"Password123!\",\n  \"confirmPassword\": \"Password123!\",\n  \"fullName\": \"John Doe\",\n  \"phoneNumber\": \"1234567890\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/register",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "register"]
            },
            "description": "Step 1 of Registration. Validates input, generates OTP, and sends email. Returns confirmation message."
          },
          "response": []
        },
        {
          "name": "Register Step 2: Verify & Complete",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var jsonData = pm.response.json();",
                  "    if (jsonData.data && jsonData.data.access_token) {",
                  "        pm.environment.set(\"access_token\", jsonData.data.access_token);",
                  "        pm.environment.set(\"refresh_token\", jsonData.data.refresh_token);",
                  "        console.log(\"Tokens saved to environment\");",
                  "    }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"testuser@example.com\",\n  \"otp\": \"123456\",\n  \"deviceId\": \"web-device-001\",\n  \"deviceType\": \"WEB\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/register/verify",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "register", "verify"]
            },
            "description": "Step 2 of Registration. Verifies OTP, creates account, and returns tokens."
          },
          "response": []
        },
        {
          "name": "Forgot Password (Step 1)",
          "event": [],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"testuser@example.com\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/forgot-password",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "forgot-password"]
            },
            "description": "Initiate password reset. Sends OTP to email."
          },
          "response": []
        },
        {
          "name": "Reset Password (Step 2)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var jsonData = pm.response.json();",
                  "    if (jsonData.data && jsonData.data.access_token) {",
                  "        pm.environment.set(\"access_token\", jsonData.data.access_token);",
                  "        pm.environment.set(\"refresh_token\", jsonData.data.refresh_token);",
                  "        console.log(\"Tokens saved to environment\");",
                  "    }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"testuser@example.com\",\n  \"otp\": \"123456\",\n  \"newPassword\": \"NewPassword123!\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/reset-password",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "reset-password"]
            },
            "description": "Complete password reset. Verifies OTP, updates password, and returns new tokens."
          },
          "response": []
        },
        {
          "name": "Login with Phone Number",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var jsonData = pm.response.json();",
                  "    if (jsonData.data && jsonData.data.access_token) {",
                  "        pm.environment.set(\"access_token\", jsonData.data.access_token);",
                  "        pm.environment.set(\"refresh_token\", jsonData.data.refresh_token);",
                  "        console.log(\"Tokens saved to environment\");",
                  "    }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phoneNumber\": \"1234567890\",\n  \"password\": \"Password123!\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/login",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "login"]
            },
            "description": "Login with phone number and password. Returns JWT access token and refresh token."
          },
          "response": []
        },
        {
          "name": "Refresh Access Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var jsonData = pm.response.json();",
                  "    if (jsonData.data && jsonData.data.access_token) {",
                  "        pm.environment.set(\"access_token\", jsonData.data.access_token);",
                  "        console.log(\"New access token saved\");",
                  "    }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refresh_token}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/refresh",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "refresh"]
            },
            "description": "Refresh the access token using the refresh token. The refresh token remains the same."
          },
          "response": []
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refresh_token}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/logout",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "logout"]
            },
            "description": "Logout user using refresh token."
          },
          "response": []
        },
        {
          "name": "Validate Token",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/auth/validate?token={{access_token}}",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "validate"],
              "query": [
                {
                  "key": "token",
                  "value": "{{access_token}}"
                }
              ]
            },
            "description": "Validate if a JWT token is valid and not expired. Returns true/false."
          },
          "response": []
        }
      ],
      "description": "Authentication endpoints for register, login, token refresh, and validation"
    },
    {
      "name": "Protected Endpoints (Examples)",
      "item": [
        {
          "name": "Get Current User (Example)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/users/me",
              "host": ["{{base_url}}"],
              "path": ["api", "users", "me"]
            },
            "description": "Example of a protected endpoint. Requires valid JWT token in Authorization header."
          },
          "response": []
        },
        {
          "name": "Test Without Token (Should Fail)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/users/me",
              "host": ["{{base_url}}"],
              "path": ["api", "users", "me"]
            },
            "description": "Test accessing a protected endpoint without token. Should return 401 Unauthorized."
          },
          "response": []
        }
      ],
      "description": "Example protected endpoints that require JWT authentication"
    },
    {
      "name": "Security Test Endpoints",
      "item": [
        {
          "name": "Public Endpoint (No Auth)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/users/test/security/public",
              "host": ["{{base_url}}"],
              "path": ["api", "users", "test", "security", "public"]
            },
            "description": "Public endpoint - accessible without authentication. Tests that SecurityContextFilter allows public paths."
          },
          "response": []
        },
        {
          "name": "Authenticated Endpoint",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/users/test/security/authenticated",
              "host": ["{{base_url}}"],
              "path": ["api", "users", "test", "security", "authenticated"]
            },
            "description": "Requires any authenticated user. Returns user info from security context."
          },
          "response": []
        },
        {
          "name": "Admin Only Endpoint",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/users/test/security/admin-only",
              "host": ["{{base_url}}"],
              "path": ["api", "users", "test", "security", "admin-only"]
            },
            "description": "@PreAuthorize('hasRole(ADMIN)') - Only ADMIN role can access. USER role will get 403."
          },
          "response": []
        },
        {
          "name": "User or Admin Endpoint",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/users/test/security/user-or-admin",
              "host": ["{{base_url}}"],
              "path": ["api", "users", "test", "security", "user-or-admin"]
            },
            "description": "@PreAuthorize('hasAnyRole(USER, ADMIN)') - Both USER and ADMIN roles can access."
          },
          "response": []
        },
        {
          "name": "Who Am I",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/users/test/security/whoami",
              "host": ["{{base_url}}"],
              "path": ["api", "users", "test", "security", "whoami"]
            },
            "description": "Returns current authenticated user information from security context."
          },
          "response": []
        },
        {
          "name": "Get User Profile (Path Variable Auth)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/users/test/security/users/{{user_id}}/profile",
              "host": ["{{base_url}}"],
              "path": [
                "api",
                "users",
                "test",
                "security",
                "users",
                "{{user_id}}",
                "profile"
              ]
            },
            "description": "@PreAuthorize('#userId == authentication.principal.id') - User can only access their own profile. Set {{user_id}} in environment."
          },
          "response": []
        },
        {
          "name": "Delete User (Complex Auth)",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/users/test/security/users/{{user_id}}",
              "host": ["{{base_url}}"],
              "path": [
                "api",
                "users",
                "test",
                "security",
                "users",
                "{{user_id}}"
              ]
            },
            "description": "@PreAuthorize('hasRole(ADMIN) or #userId == authentication.principal.id') - ADMIN can delete anyone, USER can only delete themselves."
          },
          "response": []
        },
        {
          "name": "Check Security Headers",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/users/test/security/headers",
              "host": ["{{base_url}}"],
              "path": ["api", "users", "test", "security", "headers"]
            },
            "description": "Shows all security headers (X-User-Id, X-User-Email, X-User-Roles) passed from gateway to service."
          },
          "response": []
        }
      ],
      "description": "Security context filter test endpoints - demonstrates @PreAuthorize, role-based access, and security context functionality"
    },
    {
      "name": "i18n Testing",
      "item": [
        {
          "name": "Trigger Error (Default/EN)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/users/me",
              "host": ["{{base_url}}"],
              "path": ["api", "users", "me"]
            },
            "description": "Trigger an error (401 Unauthorized) without specifying a language. Should return English message by default."
          },
          "response": []
        },
        {
          "name": "Trigger Error (Vietnamese)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept-Language",
                "value": "vi",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/users/me",
              "host": ["{{base_url}}"],
              "path": ["api", "users", "me"]
            },
            "description": "Trigger an error (401 Unauthorized) with Accept-Language: vi. Should return Vietnamese message."
          },
          "response": []
        }
      ],
      "description": "Tests for Internationalization (i18n)"
    },
    {
      "name": "User Service",
      "item": [
        {
          "name": "Create User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Manual User\",\n  \"dob\": \"2000-01-01\",\n  \"bio\": \"Created manually\",\n  \"gender\": \"MALE\",\n  \"accountId\": \"manual_account_id\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/users",
              "host": ["{{base_url}}"],
              "path": ["api", "users"]
            },
            "description": "Create a new user profile manually."
          },
          "response": []
        },
        {
          "name": "Get All Users",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/users",
              "host": ["{{base_url}}"],
              "path": ["api", "users"]
            },
            "description": "Retrieve a list of all users."
          },
          "response": []
        },
        {
          "name": "Get User By ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/users/{{user_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "users", "{{user_id}}"]
            },
            "description": "Retrieve a specific user by ID. Set user_id in environment or replace in URL."
          },
          "response": []
        },
        {
          "name": "Update User",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Updated Name\",\n  \"dob\": \"1990-01-01\",\n  \"bio\": \"Updated Bio\",\n  \"gender\": \"FEMALE\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/users/{{user_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "users", "{{user_id}}"]
            },
            "description": "Update an existing user profile."
          },
          "response": []
        },
        {
          "name": "Delete User",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/users/{{user_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "users", "{{user_id}}"]
            },
            "description": "Delete a user profile by ID."
          },
          "response": []
        }
      ],
      "description": "CRUD endpoints for User Service"
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8080",
      "type": "string"
    }
  ]
}
